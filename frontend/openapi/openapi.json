            "title": "Id"
          },
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          },
          "location_id": {
            "type": "integer",
            "title": "Location Id"
          }
