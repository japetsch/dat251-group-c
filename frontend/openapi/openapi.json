{
  "openapi": "3.1.0",
  "info": {
    "title": "Blood Bank API",
    "description": "API for the Blood Bank project",
    "version": "0.1.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Log In",
        "operationId": "log_in",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestData"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "401": {
            "description": "Unauthorized. Incorrect email or password"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Log Out",
        "operationId": "log_out",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Me",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          }
        }
      }
    },
    "/appointment": {
      "get": {
        "summary": "Find All",
        "operationId": "find_all",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GetAppointmentsByUserIdRow"
                  },
                  "type": "array",
                  "title": "Response Find All Appointment Get"
                }
              }
            }
          }
        }
      }
    },
    "/appointment/{appointment_id}": {
      "patch": {
        "summary": "Update",
        "operationId": "update",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Appointment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateAppointmentRow"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/bookingslot/available": {
      "get": {
        "summary": "Get Available",
        "operationId": "get_available",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GetBookingSlotsRow"
                  },
                  "type": "array",
                  "title": "Response Get Available Bookingslot Available Get"
                }
              }
            }
          }
        }
      }
    },
    "/bookingslot/book": {
      "post": {
        "summary": "Book",
        "operationId": "book",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookAppointmentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookBookingslotRow"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppointmentUpdateRequest": {
        "properties": {
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "cancelled": {
            "type": "boolean",
            "title": "Cancelled"
          }
        },
        "type": "object",
        "required": [
          "bookingslot_id",
          "cancelled"
        ],
        "title": "AppointmentUpdateRequest"
      },
      "BookAppointmentRequest": {
        "properties": {
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          }
        },
        "type": "object",
        "required": [
          "bookingslot_id"
        ],
        "title": "BookAppointmentRequest"
      },
      "BookBookingslotRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "donor_id": {
            "type": "integer",
            "title": "Donor Id"
          },
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "cancelled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cancelled"
          }
        },
        "type": "object",
        "required": [
          "id",
          "donor_id",
          "bookingslot_id",
          "cancelled"
        ],
        "title": "BookBookingslotRow"
      },
      "GetAppointmentsByUserIdRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "username": {
            "type": "string",
            "title": "Username"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          },
          "duration": {
            "type": "string",
            "format": "duration",
            "title": "Duration"
          },
          "bloodbank_name": {
            "type": "string",
            "title": "Bloodbank Name"
          },
          "cancelled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cancelled"
          }
        },
        "type": "object",
        "required": [
          "id",
          "username",
          "time",
          "duration",
          "bloodbank_name",
          "cancelled"
        ],
        "title": "GetAppointmentsByUserIdRow"
      },
      "GetBookingSlotsRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          },
          "duration": {
            "type": "string",
            "format": "duration",
            "title": "Duration"
          },
          "capacity": {
            "type": "integer",
            "title": "Capacity"
          },
          "bloodbank_id": {
            "type": "integer",
            "title": "Bloodbank Id"
          },
          "bloodbank_name": {
            "type": "string",
            "title": "Bloodbank Name"
          },
          "location_id": {
            "type": "integer",
            "title": "Location Id"
          }
        },
        "type": "object",
        "required": [
          "id",
          "time",
          "duration",
          "capacity",
          "bloodbank_id",
          "bloodbank_name",
          "location_id"
        ],
        "title": "GetBookingSlotsRow"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequestData": {
        "properties": {
          "email": {
            "type": "string",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequestData"
      },
      "UpdateAppointmentRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "cancelled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cancelled"
          },
          "donor_id": {
            "type": "integer",
            "title": "Donor Id"
          }
        },
        "type": "object",
        "required": [
          "id",
          "bookingslot_id",
          "cancelled",
          "donor_id"
        ],
        "title": "UpdateAppointmentRow"
      },
      "UserInfo": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "user_name": {
            "type": "string",
            "title": "User Name"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "user_name"
        ],
        "title": "UserInfo"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}