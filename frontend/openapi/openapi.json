      },
      "AppointmentUpdateRequest": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          }
        },
        "type": "object",
        "required": [
          "id",
          "time"
        ],
        "title": "AppointmentUpdateRequest"
      },
      "GetAllAppointmentsRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "username": {
            "type": "string",
            "title": "Username"
          },
          "locationname": {
            "type": "string",
            "title": "Locationname"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          }
        },
        "type": "object",
        "required": [
          "id",
          "username",
          "locationname",
          "time"
        ],
