{
  "openapi": "3.1.0",
  "info": {
    "title": "Blood Bank API",
    "description": "API for the Blood Bank project",
    "version": "0.1.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Log In",
        "operationId": "log_in",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestData"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "401": {
            "description": "Unauthorized. Incorrect email or password"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Log Out",
        "operationId": "log_out",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Me",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          }
        }
      }
    },
    "/admin/bloodbank": {
      "get": {
        "tags": [
          "admin"
        ],
        "summary": "List Bloodbanks",
        "description": "Lists all blood banks in the system, even the ones the logged in user is not adminstrator for\n\nTODO:\n- make accessible to everyone, even non-admins?\n- enhance with opening hours information\n- allow admins to list which people are admins",
        "operationId": "list_bloodbanks",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GetAllBloodBanksRow"
                  },
                  "type": "array",
                  "title": "Response List Bloodbanks Admin Bloodbank Get"
                }
              }
            }
          }
        }
      }
    },
    "/admin/bloodbank/create": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Create Bloodbank",
        "description": "Creates a new bloodbank with the logged in admin user as an administrator",
        "operationId": "create_bloodbank",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBloodBankRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/bloodbank/{bloodbank_id}/admin/add": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Add Admin To Bloodbank",
        "description": "Add another admin to a blood bank the logged in user is administrator for",
        "operationId": "add_admin_to_bloodbank",
        "parameters": [
          {
            "name": "bloodbank_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Bloodbank Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MutateBloodbankAdminsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/bloodbank/{bloodbank_id}/admin/remove": {
      "delete": {
        "tags": [
          "admin"
        ],
        "summary": "Remove Admin From Bloodbank",
        "description": "Remove an admin from a blood bank the logged in user is administrator for\n\nThe user can remove themselves.\nThe user can't remove the last admin of a blood bank.",
        "operationId": "remove_admin_from_bloodbank",
        "parameters": [
          {
            "name": "bloodbank_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Bloodbank Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MutateBloodbankAdminsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/bloodbank/{bloodbank_id}/appointment": {
      "get": {
        "tags": [
          "admin"
        ],
        "summary": "Bloodbank Appointments",
        "description": "Show appointments for blood bank.\n\nBy default only the ones scheduled after 00:00 in Oslo on the same day",
        "operationId": "bloodbank_appointments",
        "parameters": [
          {
            "name": "bloodbank_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Bloodbank Id"
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "title": "After"
            }
          },
          {
            "name": "before",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Before"
            }
          },
          {
            "name": "show_cancelled",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Show Cancelled"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookingSlotType"
                  },
                  "title": "Response Bloodbank Appointments Admin Bloodbank  Bloodbank Id  Appointment Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/appointment/{appointment_id}/note": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Appointment Add Note",
        "operationId": "appointment_add_note",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Appointment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentNote"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/appointment/{appointment_id}/donation": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Appointment Register Donation",
        "operationId": "appointment_register_donation",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Appointment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DonationInfo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/donor/{donor_id}/form/interview": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Register Interview",
        "operationId": "register_interview",
        "parameters": [
          {
            "name": "donor_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Donor Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InterviewForm"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/admin/donor/{donor_id}/form/donation-test": {
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Register Donation Test",
        "operationId": "register_donation_test",
        "parameters": [
          {
            "name": "donor_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Donor Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DonationTestForm"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/appointment": {
      "get": {
        "summary": "Find All",
        "operationId": "find_all",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GetAppointmentsByUserIdRow"
                  },
                  "type": "array",
                  "title": "Response Find All Appointment Get"
                }
              }
            }
          }
        }
      }
    },
    "/appointment/{appointment_id}": {
      "patch": {
        "summary": "Update",
        "operationId": "update",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Appointment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateAppointmentRow"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/appointment/{appointment_id}/note": {
      "post": {
        "summary": "Add Note",
        "operationId": "add_note",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Appointment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentNote"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/bookingslot/available": {
      "get": {
        "summary": "Get Available",
        "operationId": "get_available",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GetBookingSlotsRow"
                  },
                  "type": "array",
                  "title": "Response Get Available Bookingslot Available Get"
                }
              }
            }
          }
        }
      }
    },
    "/bookingslot/book": {
      "post": {
        "summary": "Book",
        "operationId": "book",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookAppointmentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookBookingslotRow"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppointmentNote": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "AppointmentNote"
      },
      "AppointmentType": {
        "properties": {
          "appointment_id": {
            "type": "integer",
            "title": "Appointment Id"
          },
          "appointment_cancelled": {
            "type": "boolean",
            "title": "Appointment Cancelled"
          },
          "donor_id": {
            "type": "integer",
            "title": "Donor Id"
          },
          "donor_blood_type": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/BloodType"
              },
              {
                "type": "null"
              }
            ]
          },
          "donor_name": {
            "type": "string",
            "title": "Donor Name"
          },
          "donor_email": {
            "type": "string",
            "title": "Donor Email"
          },
          "donor_phone": {
            "type": "string",
            "title": "Donor Phone"
          }
        },
        "type": "object",
        "required": [
          "appointment_id",
          "appointment_cancelled",
          "donor_id",
          "donor_blood_type",
          "donor_name",
          "donor_email",
          "donor_phone"
        ],
        "title": "AppointmentType"
      },
      "AppointmentUpdateRequest": {
        "properties": {
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "cancelled": {
            "type": "boolean",
            "title": "Cancelled"
          }
        },
        "type": "object",
        "required": [
          "bookingslot_id",
          "cancelled"
        ],
        "title": "AppointmentUpdateRequest"
      },
      "BloodType": {
        "type": "string",
        "enum": [
          "O+",
          "O-",
          "A+",
          "A-",
          "B+",
          "B-",
          "AB+",
          "AB-"
        ],
        "title": "BloodType"
      },
      "BookAppointmentRequest": {
        "properties": {
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          }
        },
        "type": "object",
        "required": [
          "bookingslot_id"
        ],
        "title": "BookAppointmentRequest"
      },
      "BookBookingslotRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "donor_id": {
            "type": "integer",
            "title": "Donor Id"
          },
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "cancelled": {
            "type": "boolean",
            "title": "Cancelled"
          }
        },
        "type": "object",
        "required": [
          "id",
          "donor_id",
          "bookingslot_id",
          "cancelled"
        ],
        "title": "BookBookingslotRow"
      },
      "BookingSlotType": {
        "properties": {
          "bookingslot_id": {
            "type": "integer",
            "title": "Bookingslot Id"
          },
          "bookingslot_time": {
            "type": "string",
            "format": "date-time",
            "title": "Bookingslot Time"
          },
          "bookingslot_duration": {
            "type": "string",
            "format": "duration",
            "title": "Bookingslot Duration"
          },
          "bookingslot_remaining_capacity": {
            "type": "integer",
            "title": "Bookingslot Remaining Capacity"
          },
          "appointments": {
            "items": {
              "$ref": "#/components/schemas/AppointmentType"
            },
            "type": "array",
            "title": "Appointments"
          }
        },
        "type": "object",
        "required": [
          "bookingslot_id",
          "bookingslot_time",
          "bookingslot_duration",
          "bookingslot_remaining_capacity",
          "appointments"
        ],
        "title": "BookingSlotType"
      },
      "CreateBloodBankRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "street_name": {
            "type": "string",
            "title": "Street Name"
          },
          "street_number": {
            "type": "string",
            "title": "Street Number"
          },
          "postal_code": {
            "type": "string",
            "title": "Postal Code"
          },
          "city": {
            "type": "string",
            "title": "City"
          },
          "country": {
            "type": "string",
            "title": "Country",
            "default": "NO"
          },
          "loc_lat": {
            "type": "number",
            "title": "Loc Lat"
          },
          "loc_lon": {
            "type": "number",
            "title": "Loc Lon"
          }
        },
        "type": "object",
        "required": [
          "name",
          "street_name",
          "street_number",
          "postal_code",
          "city",
          "loc_lat",
          "loc_lon"
        ],
        "title": "CreateBloodBankRequest"
      },
      "DonationInfo": {
        "properties": {
          "amount_ml": {
            "type": "number",
            "title": "Amount Ml"
          },
          "is_blood_not_plasma": {
            "type": "boolean",
            "title": "Is Blood Not Plasma",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "amount_ml"
        ],
        "title": "DonationInfo"
      },
      "DonationTestForm": {
        "properties": {
          "submitted_at": {
            "type": "string",
            "format": "date-time",
            "title": "Submitted At"
          },
          "ok_to_donate": {
            "type": "boolean",
            "title": "Ok To Donate"
          },
          "validity_duration": {
            "type": "string",
            "format": "duration",
            "title": "Validity Duration"
          },
          "donation_id": {
            "type": "integer",
            "title": "Donation Id"
          }
        },
        "type": "object",
        "required": [
          "ok_to_donate",
          "validity_duration",
          "donation_id"
        ],
        "title": "DonationTestForm"
      },
      "GetAllBloodBanksRow": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "street_name": {
            "type": "string",
            "title": "Street Name"
          },
          "street_number": {
            "type": "string",
            "title": "Street Number"
          },
          "postal_code": {
            "type": "string",
            "title": "Postal Code"
          },
          "city": {
            "type": "string",
            "title": "City"
          },
          "country": {
            "type": "string",
            "title": "Country"
          },
          "has_admin": {
            "type": "boolean",
            "title": "Has Admin"
          }
        },
        "type": "object",
        "required": [
          "name",
          "street_name",
          "street_number",
          "postal_code",
          "city",
          "country",
          "has_admin"
        ],
        "title": "GetAllBloodBanksRow"
      },
      "GetAppointmentsByUserIdRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "username": {
            "type": "string",
            "title": "Username"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          },
          "duration": {
            "type": "string",
            "format": "duration",
            "title": "Duration"
          },
          "bloodbank_name": {
            "type": "string",
            "title": "Bloodbank Name"
          },
          "cancelled": {
